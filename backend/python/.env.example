# Copy this file to .env and adjust values. Never commit .env.

# Django
SECRET_KEY=change-me-to-a-long-random-string-for-local-dev

# MongoDB connection (Django / mongoengine). Keep timeouts so runserver does not hang when Docker is down.
MONGO_URI=mongodb://YOUR_USER:YOUR_PASSWORD@localhost:27019/YOUR_DB?authSource=admin&serverSelectionTimeoutMS=2000&connectTimeoutMS=2000

# Database name passed to mongoengine.connect (path in MONGO_URI should match, e.g. /YOUR_DB).
MONGO_DB_NAME=products_db

# Used by the official MongoDB Docker image on first init only (new empty volume).
# If you change these after data exists, you must reset the volume or change the user inside Mongo.
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=your-secure-password
